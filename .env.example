# Обязательная переменная — токен от @BotFather
BOT_TOKEN=

# Один из вариантов публичного HTTPS-адреса:
# На Railway оставьте WEBHOOK_URL пустым, если сервису создан Public Domain:
# тогда автоматически используется RAILWAY_PUBLIC_DOMAIN. Не оставляйте здесь примерный домен.
WEBHOOK_URL=

# Постоянный секрет: 8–256 символов A-Z, a-z, 0-9, _ или - (без пробелов/кавычек).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET_TOKEN=

ADMIN_IDS=
DB_PATH=/data/iskra.db
DB_POOL_SIZE=8

# Опционально
REDIS_URL=
