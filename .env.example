# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Путь к базе SQLite. На Railway лучше указать volume, напр. /data/iskra.db
DB_PATH=iskra.db

# ID администраторов через запятую (для /stats)
ADMIN_IDS=

# Сколько входящих лайков показывать в превью
LIKES_PREVIEW=10

# Порт для /health (на Railway задаётся автоматически)
PORT=8080
