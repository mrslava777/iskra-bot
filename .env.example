# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456:ABC-DEF...

# ID администраторов через запятую (модерация жалоб, рассылка)
ADMIN_IDS=12345678,87654321

# Необязательно: явный путь к БД. По умолчанию /data/iskra.db (Railway Volume)
# или ./iskra.db локально.
# DB_PATH=/data/iskra.db

# Необязательно: сколько входящих лайков показывать (по умолчанию 10)
# LIKES_PREVIEW=10

# Необязательно: порт health-сервера (Railway задаёт PORT автоматически)
# PORT=8080
